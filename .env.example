# Copy to .env in the repository root and fill in values.
# Never commit .env (see .gitignore).

# GCP project used for Storage and BigQuery
GCP_PROJECT_ID=your-gcp-project-id

# Cloud Storage
GCS_BUCKET_NAME=your-gs-bucket-name
GCS_BLOB_NAME=crypto/raw/your_file.csv

# BigQuery (Bronze)
BIGQUERY_DATASET_BRONZE=crypto_bronze
BIGQUERY_TABLE_RAW=crypto_raw

# Local Kaggle CSV path (relative to repo root or absolute)
LOCAL_FILE_PATH=data/your_kaggle_export.csv
